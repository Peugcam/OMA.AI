# ============================================================================
# OMA Video Generator - Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ============================================================================

# ===================
# REQUIRED API KEYS
# ===================

# OpenRouter API Key (for LLM agents)
# Get yours at: https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# RunwayML Gen-3 API Key (for AI video generation)
# Get yours at: https://runwayml.com/
# Plan: Standard ($28/month) - 200 credits
RUNWAYML_API_KEY=rw-your-key-here

# ElevenLabs API Key (for TTS narration)
# Get yours at: https://elevenlabs.io/
# Plan: Starter ($22/month) - 100k characters
ELEVENLABS_API_KEY=sk-your-elevenlabs-key-here
ELEVENLABS_VOICE_ID=your-voice-id-here

# ===================
# DEPRECATED (NOT USED)
# ===================

# Pexels API Key (REPLACED by RunwayML Gen-3)
# PEXELS_API_KEY=

# Stability AI (NOT NEEDED with RunwayML)
# STABILITY_API_KEY=

# ===================
# APPLICATION CONFIG
# ===================

# Environment (development, staging, production)
ENVIRONMENT=development

# Debug mode (true/false)
DEBUG=false

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ===================
# SECURITY
# ===================

# Secret key for JWT signing (generate a strong random string for production)
# You can generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-in-production

# ===================
# SERVER CONFIG
# ===================

# Server host (0.0.0.0 for all interfaces)
API_HOST=0.0.0.0

# Server port (will be overridden by platform in production)
API_PORT=8000

# CORS origins (comma-separated list)
CORS_ORIGINS=http://localhost:7860,http://localhost:3000

# ===================
# VIDEO GENERATION
# ===================

# Default video duration in seconds (start with 15-20s)
DEFAULT_VIDEO_DURATION=20

# Maximum video duration in seconds
MAX_VIDEO_DURATION=30

# Number of clips per video (20s = 4 clips of 5s each)
CLIPS_PER_VIDEO=4

# Maximum concurrent video generations
MAX_CONCURRENT_GENERATIONS=3

# Task timeout in seconds (10 minutes default)
TASK_TIMEOUT_SECONDS=600

# ===================
# RUNWAYML CONFIG
# ===================

# Model to use (gen3a_turbo recommended for speed)
RUNWAYML_MODEL=gen3a_turbo

# Duration of each clip in seconds
RUNWAYML_CLIP_DURATION=5

# Video resolution (720p or 1080p)
RUNWAYML_RESOLUTION=1080p

# ===================
# ELEVENLABS CONFIG
# ===================

# Voice model (multilingual v2 for Portuguese)
ELEVENLABS_MODEL=eleven_multilingual_v2

# Voice settings (0.0 to 1.0)
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SIMILARITY_BOOST=0.75
ELEVENLABS_STYLE=0.2

# ===================
# OPENROUTER CONFIG
# ===================

# Model for creative scripts
OPENROUTER_SCRIPT_MODEL=anthropic/claude-3.5-sonnet

# Model for product analysis (with vision)
OPENROUTER_VISION_MODEL=anthropic/claude-3.5-sonnet

# Fallback model (optional, cheaper)
OPENROUTER_FALLBACK_MODEL=google/gemini-pro-1.5
